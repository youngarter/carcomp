generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS (Domaine Automobile)
// ==========================================

enum FuelType {
  ESSENCE
  DIESEL
  HYBRIDE
  PHEV // Hybride rechargeable
  ELECTRIQUE
}

enum Transmission {
  MANUELLE
  AUTOMATIQUE
}

enum BodyType {
  SUV
  CITADINE
  BERLINE
  BREAK
  COUPE
  CABRIOLET
  PICKUP
  MONOSPACE
}

// ==========================================
// AUTHENTIFICATION & UTILISATEURS
// ==========================================

model User {
  id           String          @id @default(uuid())
  name         String?
  email        String?         @unique
  password     String?
  image        String?
  roleId       String?
  role         Role?           @relation(fields: [roleId], references: [id])
  accounts     Account[]
  sessions     Session[]
  activityLogs ActivityLog[]
  preferences  UserPreference?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // "SUPER_ADMIN", "ADMIN", "USER"
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique // "EDIT_CAR", "DELETE_CAR", "MANAGE_USERS"
  roles Role[] @relation("RolePermissions")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model UserPreference {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  budgetMin  Float?
  budgetMax  Float?
  usage      String? // Urbain, Autoroute, Mixte
  passengers Int?
  priority   String? // Confort, Économie, Sport
  createdAt  DateTime @default(now())
}

// ==========================================
// CATALOGUE AUTOMOBILE (Architecture Optimisée)
// ==========================================

model Brand {
  id          String     @id @default(uuid())
  slug        String     @unique
  name        String     @unique
  origin      String?
  image       String?
  imageAlt    String?
  logo        String?
  logoAlt     String?
  description String?    @db.Text
  models      CarModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model CarModel {
  id       String   @id @default(uuid())
  slug     String   @unique
  name     String
  brandId  String
  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category BodyType
  image    String?

  // Scoring pré-calculé pour tri et recommandations IA
  aiScore     Float?
  reliability Float?
  maintCost   Float?

  // Cache des prix pour requêtes ultra-rapides (en centimes / dirhams)
  minPrice Int? @default(0)
  maxPrice Int? @default(0)

  generations CarGeneration[]
  finitions   Finition[]
  reviews     Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([category])
}

model CarGeneration {
  id         String     @id @default(uuid())
  slug       String     @unique
  name       String
  carModelId String
  carModel   CarModel   @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  startYear  Int
  endYear    Int? // Null = Toujours en production
  phaseType  String // e.g., "new", "facelift"
  isCurrent  Boolean    @default(false)
  images     String[]   @default([])
  finitions  Finition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carModelId])
}

model Finition {
  id           String         @id @default(uuid())
  slug         String         @unique
  name         String
  carModelId   String
  carModel     CarModel       @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  generationId String?
  generation   CarGeneration? @relation(fields: [generationId], references: [id])

  basePrice      Int? // Prix de base en centimes
  year           Int?
  isDiscontinued Boolean  @default(false)
  isPromoted     Boolean  @default(false)
  images         String[] @default([])
  youtubeVideo   String?

  // Relation 1-to-1 stricte vers la mécanique (pour les filtres)
  technicalSpecs TechnicalSpec?

  // Les équipements variables (JSONB)
  safetyFeatures    Json @default("{}")
  comfortFeatures   Json @default("{}")
  aestheticFeatures Json @default("{}")

  priceHistory FinitionPriceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carModelId])
  @@index([basePrice])
}

model TechnicalSpec {
  id         String   @id @default(uuid())
  finitionId String   @unique
  finition   Finition @relation(fields: [finitionId], references: [id], onDelete: Cascade)

  // Moteur & Energie
  fuelType           FuelType
  transmission       Transmission
  engineDisplacement Int? // Cylindrée en cm3
  dinPower           Int? // Puissance ch
  fiscalPower        Int? // CV fiscaux
  batteryCapacity    Float? // Capacité batterie (kWh)
  electricRange      Int? // Autonomie électrique (km)
  maxTorque          Int? // Couple Max (Nm)

  // Performances & Conso
  topSpeed     Int? // km/h
  acceleration Float? // 0-100 km/h en s
  consoCity    Float? // L/100km
  consoRoad    Float? // L/100km
  consoMixed   Float? // L/100km
  co2Emission  Int? // g/km

  // Dimensions & Poids
  trunkVolume Int? // Volume coffre (L)
  tankVolume  Int? // Volume réservoir (L)
  seats       Int  @default(5)
  weight      Int? // Poids (kg)
  length      Int? // mm
  width       Int? // mm
  height      Int? // mm
  wheelbase   Int? // mm

  // Indexes stratégiques pour la recherche
  @@index([fuelType])
  @@index([transmission])
  @@index([dinPower])
  @@index([consoMixed])
}

model FinitionPriceHistory {
  id               String    @id @default(uuid())
  finitionId       String
  finition         Finition  @relation(fields: [finitionId], references: [id], onDelete: Cascade)
  price            Int // Prix en centimes
  isPromotion      Boolean   @default(false)
  promotionalPrice Int? // Prix remisé en centimes
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime  @default(now())

  @@index([finitionId])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(uuid())
  carModelId  String
  carModel    CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  rating      Int // 1-5
  comment     String   @db.Text
  isAiSummary Boolean  @default(false)
  userName    String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())

  @@index([carModelId])
}

// ==========================================
// BLOG & CMS
// ==========================================

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Article {
  id         String   @id @default(uuid())
  title      String
  subtitle   String?
  slug       String   @unique
  content    String   @db.Text
  coverImage String?
  images     String[] @default([])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
}

model HeroSlide {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  price       String?
  url         String?
  image       String
  imageAlt    String?
  brandLogo   String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AUTH.JS (NextAuth) MODELS
// ==========================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
